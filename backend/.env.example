APP_NAME=Vigia API
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=True
SECRET_KEY=dev-insecure-secret-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgres://vigia:vigia@localhost:5432/vigia
# Supabase deploy: use the Transaction pooler (port 6543) for serverless runtimes
# (Lambda). Copy the string from the dashboard's "Connect" panel — the region in
# the host must match your project, and the username is postgres.<project-ref>.
# The project must be active (un-pause it) or the pooler returns "tenant not found".
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
ANTHROPIC_API_KEY=your-key-here
